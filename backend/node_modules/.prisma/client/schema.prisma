generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  name     String?
  email    String  @unique
  password String
  role     String  @default("USER")
}

model Employee {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  position  String
  salary    Float
  createdAt DateTime @default(now())
}
